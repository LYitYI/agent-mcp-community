{
  "name": "@xhy/mcp-surge-server",
  "version": "0.2.0",
  "description": "MCP server for deploying static sites to surge.sh — supports custom domain, teardown, and env-based auth",
  "type": "module",
  "bin": "./build/index.js",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "surge",
    "surge.sh",
    "deploy",
    "static-site"
  ],
  "author": "xhy",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
